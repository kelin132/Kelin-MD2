# ─────────────────────────────────────────────────────────
#  KELIN MD — Bot Configuration
#  Copy this file to .env and fill in your values.
#  On Pterodactyl / katabump / bothosting panels paste these
#  directly into the panel's Environment Variables tab.
# ─────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────
# Your WhatsApp number WITH country code, NO + or spaces
BOT_NUMBER=263719809572

# Your personal WhatsApp number (owner commands only)
# For multiple owners separate with commas: 263xxx,263yyy
OWNER_NUMBER=263719809572

# ── Database (required for economy/guild/staff) ───────────
# MongoDB connection string — get a free cluster at mongodb.com/atlas
MONGO_URI=

# ── AI Features ───────────────────────────────────────────
# Google Gemini API key — powers ALL AI commands + Akira
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────
BOT_NAME=KELIN MD
PREFIX=.
TZ=Africa/Harare
SESSION_FOLDER=sessions
