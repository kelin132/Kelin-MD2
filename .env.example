# ─────────────────────────────────────────────────────────
#  KELIN MD — Bot Configuration
#  Copy this file to .env and fill in your values.
#  On Pterodactyl / katabump / bothosting panels you can
#  paste these directly into the panel's Environment tab.
# ─────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────

# Your WhatsApp number WITH country code, NO + or spaces
# Example: 2348012345678  (Nigeria +234)
#          12025551234    (USA +1)
BOT_NUMBER=

# Your personal WhatsApp number (owner commands only)
OWNER_NUMBER=

# ── Optional ─────────────────────────────────────────────

# Bot name shown in menus
BOT_NAME=KELIN MD

# Command prefix
PREFIX=.

# Session folder (leave as default unless you know what you're doing)
SESSION_FOLDER=sessions

# Timezone for time-based commands
TZ=Africa/Lagos
