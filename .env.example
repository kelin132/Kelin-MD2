# ─────────────────────────────────────────────────────────────────────────────
#  KELIN MD — Environment Configuration
#  Copy this file to .env and fill in your values.
#
#  On Pterodactyl / panel hosting: paste these into the
#  "Environment Variables" tab — no .env file needed there.
# ─────────────────────────────────────────────────────────────────────────────

# ── BOT NUMBER ────────────────────────────────────────────────────────────────
# The WhatsApp number the BOT itself runs on.
# Used for the pairing code when linking your session.
# Country code + number, NO + symbol, NO spaces.
# Example: 27628114340  (South Africa)  |  2637XXXXXXXX  (Zimbabwe)
BOT_NUMBER=27628114340

# ── OWNER NUMBER ─────────────────────────────────────────────────────────────
# YOUR personal WhatsApp number — the person who controls the bot.
# This number gets full owner access to ALL .owner commands.
# Country code + number, NO + symbol, NO spaces.
#
# ✅ If you run the bot on your OWN number: set this to the SAME number as BOT_NUMBER
# ✅ If you run the bot on a SEPARATE number: set this to YOUR personal number
#
# Example: 27628114340
OWNER_NUMBER=27628114340

# ── DATABASE ──────────────────────────────────────────────────────────────────
# MongoDB connection string — required for economy, guild, staff, and premium features.
# Get a free cluster at: https://mongodb.com/atlas
# Leave blank to run without MongoDB (economy/guild/staff commands won't work).
MONGO_URI=

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini API key — powers all AI commands and the Akira chatbot.
# Get one free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
BOT_NAME=AKIRA 
PREFIX=.
TZ=Africa/Harare
SESSION_FOLDER=sessions

# GitHub personal access token — used by .update command to pull latest code.
# Create one at: https://github.com/settings/tokens (read-only repo scope is enough)
GITHUB_TOKEN= 

# ── CARD SYSTEM ───────────────────────────────────────────────────────────────
# RapidAPI key for the Anime Card Database API.
# Get yours at: https://rapidapi.com/  (search "anime-db")
# Required for: .card  .cardsearch  .collection  .drop  .collect  .inv  .trade
# Auto-spawn (every 15 min in groups): enable with .cardspawn on
RAPIDAPI_KEY=de17ce8e88msh32236a8c181ca21p106b2bjsn04928a2afcda
